{
  "name": "@goatlab/delphi-sandbox",
  "version": "0.1.3",
  "description": "Sandboxed Docker execution environments for the Goat agent workflow engine",
  "homepage": "https://docs.goatlab.io",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "ignacio.cabrera@goatlab.io",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "./dist/**/*"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit/",
    "test:integration": "vitest run src/__tests__/integration/",
    "test:e2e": "vitest run src/__tests__/e2e/",
    "dev": "tsc --watch",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "build": "tsc"
  },
  "dependencies": {
    "@goatlab/delphi-core": "workspace:*",
    "@goatlab/delphi-ai": "workspace:*",
    "@goatlab/js-utils": "^0.10.3",
    "dockerode": "^4.0.4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@goatlab/biome": "^0.1.1",
    "@goatlab/tsconfig": "^0.2.0",
    "@goatlab/tasks-adapter-bullmq": "^0.10.1",
    "@testcontainers/postgresql": "^11.0.3",
    "@testcontainers/redis": "^11.0.3",
    "@types/dockerode": "^3.3.34",
    "@types/node": "^22.10.7",
    "kysely": "^0.27.6",
    "pg": "^8.13.0",
    "testcontainers": "^11.0.3",
    "vitest": "^3.1.1"
  }
}
