{
	"name": "@goatlab/delphi-express-example",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Blank Express + Prisma app showing how to mount the agent engine via @goatlab/delphi-express",
	"scripts": {
		"infra:up": "docker compose up -d",
		"infra:down": "docker compose down -v --remove-orphans",
		"infra:logs": "docker compose logs -f",
		"db:push": "prisma db push --skip-generate",
		"db:generate": "prisma generate",
		"build": "tsc",
		"start": "tsx src/server.ts",
		"dev": "tsx watch src/server.ts",
		"loadtest": "bash scripts/loadtest.sh",
		"loadtest:horizontal": "bash scripts/horizontal-loadtest.sh",
		"verify": "bash scripts/verify.sh"
	},
	"dependencies": {
		"@goatlab/delphi-core": "workspace:*",
		"@goatlab/delphi-express": "workspace:*",
		"@goatlab/realtime-broker": "workspace:*",
		"@goatlab/tasks-adapter-bullmq": "workspace:*",
		"@prisma/client": "^6.1.0",
		"express": "^4.21.2",
		"ioredis": "^5.4.1",
		"kysely": "^0.27.6",
		"pg": "^8.20.0"
	},
	"devDependencies": {
		"@types/express": "^4.17.21",
		"@types/node": "^22.10.7",
		"@types/pg": "^8.11.10",
		"prisma": "^6.1.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.0"
	}
}
