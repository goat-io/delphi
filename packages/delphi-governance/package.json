{
  "name": "@goatlab/delphi-governance",
  "version": "0.1.0",
  "description": "Governance bridge for the Delphi agent OS — compiles approved Brain Decisions/Actions into delphi-core workflow runs, gates them through a Constitution, and records outcomes back. The seam that makes the Company Brain executable.",
  "homepage": "https://docs.goatlab.io",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "ignacio.cabrera@goatlab.io",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "./dist/**/*"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "test": "vitest run",
    "dev": "tsc --watch",
    "lint": "biome check --write .",
    "build": "tsc",
    "example:self-improve": "tsx example/self-improve.ts"
  },
  "peerDependencies": {
    "@goatlab/delphi-core": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@goatlab/delphi-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@goatlab/biome": "^0.1.1",
    "@goatlab/delphi-core": "workspace:*",
    "@goatlab/tsconfig": "^0.2.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "rimraf": "^6.0.0",
    "tslib": "^2.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
