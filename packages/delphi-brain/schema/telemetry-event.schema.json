{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://delphi.goat.io/brain/schema/telemetry-event.schema.json",
  "title": "kind: telemetry-event",
  "description": "One observation of something happening in Brain — skill completion, chat query, lint finding, schema validation event, edge-pattern detection, query-gap. Substrate for /brain-evolve.",
  "type": "object",
  "required": ["ts", "kind"],
  "additionalProperties": true,
  "properties": {
    "ts":            {"type": "string", "format": "date-time", "description": "ISO-8601 UTC"},
    "kind":          {"type": "string", "enum": [
      "skill-complete",
      "chat-query",
      "lint-finding",
      "validation-fail",
      "edge-pattern",
      "query-gap",
      "candidate-stage",
      "candidate-promote",
      "candidate-discard",
      "schema-change",
      "ingest"
    ]},
    "skill":         {"type": "string", "description": "skill name for skill-complete"},
    "entries":       {"type": "array",  "items": {"type": "string"}, "description": "catalog/narrative paths touched"},
    "ad-hoc-fields": {"type": "array",  "items": {"type": "string"}, "description": "frontmatter/catalog-info fields that aren't in any kind schema yet"},
    "new-edge-types":{"type": "array",  "items": {"type": "string"}, "description": "edge type strings not yet enumerated in dependsOn/relations"},
    "q":             {"type": "string", "description": "the user's chat query (chat-query)"},
    "rag-hits":      {"type": "integer", "minimum": 0},
    "answered":      {"type": "boolean"},
    "user-followed-up": {"type": "boolean"},
    "type":          {"type": "string", "description": "finding sub-type for lint-finding (orphan-page, broken-link, stale, contradiction, ad-hoc-field-cluster, missing-back-edge, query-gap)"},
    "path":          {"type": "string"},
    "severity":      {"type": "string", "enum": ["soft", "pattern", "hard"]},
    "value":         {"type": "string", "description": "the repeated value for edge-pattern"},
    "occurrences":   {"type": "integer", "minimum": 1},
    "first-seen":    {"type": "string", "format": "date-time"},
    "topic":         {"type": "string", "description": "for query-gap"},
    "queries-in-7d": {"type": "integer", "minimum": 0},
    "page-exists":   {"type": "boolean"},
    "schema":        {"type": "string", "description": "kind name for validation-fail"},
    "entry":         {"type": "string"},
    "missing-required": {"type": "array", "items": {"type": "string"}},
    "source":        {"type": "string", "description": "for ingest events — raw/sources/<path>"},
    "target-path":   {"type": "string", "description": "for candidate-stage/promote events"}
  }
}
