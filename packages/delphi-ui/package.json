{
  "name": "@goatlab/delphi-ui",
  "version": "0.1.10",
  "description": "Workflow dashboard for the Goat agent ecosystem",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode library",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "test:e2e": "playwright test",
    "test:server": "tsx test-server/server.ts",
    "example:backend": "tsx example/start.ts",
    "example:ui": "VITE_API_URL=http://localhost:4444 vite --port 5173"
  },
  "dependencies": {
    "@xyflow/react": "^12.6.4",
    "dagre": "^0.8.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@goatlab/biome": "^0.1.1",
    "@types/dagre": "^0.7.52",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.5",
    "tailwindcss": "^4.1.8",
    "@tailwindcss/vite": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "@playwright/test": "^1.52.0",
    "@goatlab/delphi-core": "workspace:*",
    "@goatlab/tasks-adapter-bullmq": "^0.10.1",
    "@testcontainers/postgresql": "^11.0.3",
    "@testcontainers/redis": "^11.0.3",
    "testcontainers": "^11.0.3",
    "kysely": "^0.27.6",
    "pg": "^8.13.0",
    "tsx": "^4.19.0"
  }
}
