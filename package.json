{
  "name": "delphi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "demo": "tsx scripts/demo.ts",
    "api": "tsx apps/api/src/server.ts",
    "mcp": "tsx apps/mcp/src/server.ts",
    "brain:bootstrap": "tsx scripts/bootstrap-brain.ts",
    "bt": "pnpm typecheck && pnpm lint:check && pnpm test",
    "build:packages": "pnpm -r --filter './packages/**' build",
    "test:engine": "pnpm -r --filter './packages/delphi-core' --filter './packages/delphi-ai' --filter './packages/delphi-langgraph' --filter './packages/delphi-sandbox' --filter './packages/realtime-broker' test",
    "lint": "biome check --write packages/delphi-protocol packages/delphi-knowledge packages/delphi-ingestion packages/delphi-extraction packages/delphi-indexer packages/delphi-agent apps/api apps/mcp scripts tests",
    "lint:check": "biome check packages/delphi-protocol packages/delphi-knowledge packages/delphi-ingestion packages/delphi-extraction packages/delphi-indexer packages/delphi-agent apps/api apps/mcp scripts tests",
    "format": "biome format --write packages/delphi-protocol packages/delphi-knowledge packages/delphi-ingestion packages/delphi-extraction packages/delphi-indexer packages/delphi-agent apps/api apps/mcp scripts tests",
    "evolve": "tsx scripts/evolve.ts",
    "evolve:loop": "tsx scripts/evolution-loop.ts",
    "evolve:engine": "tsx scripts/evolution-workflow.ts",
    "evolve:server": "tsx scripts/evolution-server.ts",
    "evolve:worker": "tsx scripts/evolution-worker.ts",
    "evolve:daemon": "tsx scripts/evolution-daemon.ts",
    "evolve:cycle-once": "tsx scripts/evolution-cycle-once.ts",
    "evolution:state": "tsx scripts/evolution-state.ts",
    "dashboard": "tsx scripts/dashboard-server.ts",
    "dashboard:ui": "pnpm --filter delphi-dashboard dev",
    "dashboard:build": "pnpm --filter delphi-dashboard build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@goatlab/biome": "^0.1.1",
    "@goatlab/tsconfig": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@electric-sql/pglite": "^0.5.2",
    "@electric-sql/pglite-socket": "^0.2.2",
    "@goatlab/delphi-core": "workspace:*",
    "fastify": "^5.8.5",
    "pg": "^8.21.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "license": "MIT"
}
