// Mirrors @goatlab/tsconfig@0.2.0 minus CJS/removed options (suppressImplicitAnyIndexErrors, module commonjs);
// knowledge plane is ESM.
{
  "compilerOptions": {
    "target": "es2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["es2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "newLine": "lf",
    "pretty": true,
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "incremental": false,
    "importHelpers": false,
    "paths": {
      "@goatlab/delphi-governance": ["./packages/delphi-governance/dist/index.d.ts"]
    }
  },
  "include": [
    "packages/delphi-protocol/src/**/*.ts",
    "packages/delphi-knowledge/src/**/*.ts",
    "packages/delphi-ingestion/src/**/*.ts",
    "packages/delphi-extraction/src/**/*.ts",
    "packages/delphi-indexer/src/**/*.ts",
    "packages/delphi-agent/src/**/*.ts",
    "apps/api/src/**/*.ts",
    "apps/mcp/src/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}
